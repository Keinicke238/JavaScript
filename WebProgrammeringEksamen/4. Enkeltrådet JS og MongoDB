function processUserData(name, callback) {
    const capitalizedName = name.toUpperCase();
    callback(capitalizedName);
}

processUserData('peter', (result) => {
    console.log(result);
});


class Person {
    constructor(name, age) {
        this.name = name;
        this.age = age;
    }

    introduce() {
        return `Hej, jeg hedder ${this.name} og er ${this.age} år gammel.`;
    }
}

const user1 = new Person('Jens', 30);
console.log(user1.introduce());


const mongoose = require('mongoose');

const userSchema = new mongoose.Schema({
    username: { type: String, required: true },
    email: { type: String, required: true, unique: true },
    age: Number
});

const User = mongoose.model('User', userSchema);

async function createUser() {
    const newUser = new User({
        username: 'Lise99',
        email: 'lise@mail.dk',
        age: 25
    });
    await newUser.save();
}
