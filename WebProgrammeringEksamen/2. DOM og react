import { useState } from 'react';

function UserProfile(props) {
  const [likes, setLikes] = useState(0);

  const handleLike = () => {
    setLikes(likes + 1);
  };

  return (
    <div className="profile-card">
      <h1>Navn: {props.name}</h1>
      <p>Rolle: {props.role}</p>
      <button onClick={handleLike}>
        Antal likes: {likes}
      </button>
    </div>
  );
}

function App() {
  return (
    <div className="App">
      <UserProfile name="Mario" role="Ninja" />
      <UserProfile name="Yoshi" role="Dinosaur" />
    </div>
  );
}
